    "bullmq": "^5.77.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.10.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^7.8.0",
    "svix": "^1.94.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
