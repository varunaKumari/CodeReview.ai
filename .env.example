# Server Configuration
PORT=3001
NODE_ENV=development
# Database (Neon Serverless PostgreSQL)
# Pooled connection URL (for application queries)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/codereview_ai?sslmode=require
# Direct (non-pooled) connection URL (required for Prisma migrations)
DIRECT_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/codereview_ai?sslmode=require
# Redis (Upstash Serverless Redis)
REDIS_URL=rediss://default:xxx@us1-xxx.upstash.io:6379
# Frontend URL (CORS origin)
CORS_ORIGIN=http://localhost:3000
# API
NEXT_PUBLIC_API_URL=http://localhost:3001
# Clerk Authentication
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
